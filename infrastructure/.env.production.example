# ─── Production Environment (Example / Template) ────────────────────────────────
# DO NOT commit real secrets. In Kubernetes, these values live in:
#   - ConfigMap  (non-sensitive): kubernetes/configmap.yaml
#   - Secret     (sensitive):     kubernetes/secret.yaml   (gitignored)
#
# This file is a reference template only.

APP_ENV=production

# ── Backend / Go server ────────────────────────────────────────────────────────
PORT=8080
# RDS Postgres or managed Postgres URL
DATABASE_URL=postgresql://<DB_USER>:<DB_PASS>@<RDS_HOST>:5432/video_db?sslmode=require
KAFKA_BROKERS=<REDPANDA_OR_MSK_ADDR>:9092
KAFKA_TOPIC=video-processing

# ── Storage: AWS S3 (real) ─────────────────────────────────────────────────────
S3_BUCKET=hubstream-videos-prod
AWS_REGION=us-east-1
# S3_ENDPOINT must be EMPTY (or unset) for real AWS S3
S3_ENDPOINT=
# AWS credentials come from the EC2 instance IAM role — no static keys needed.

# ── ML services: accessed via gpu-tunnel K8s Service ──────────────────────────
# The gpu-tunnel Deployment maintains an SSH port-forward to the remote GPU server.
# From inside the cluster these services are reachable at gpu-tunnel.<namespace>.svc:
TRANSCRIPTION_TARGET=gpu-tunnel.video-search.svc.cluster.local:8902
EMOTION_TARGET=gpu-tunnel.video-search.svc.cluster.local:8904
VLLM_URL=http://gpu-tunnel.video-search.svc.cluster.local:8900/v1/chat/completions
VLLM_MODEL=cyankiwi/Qwen3-VL-8B-Instruct-AWQ-4bit
